# ============================================================
# EticAlert — Apache .htaccess
# URLs limpias sin extensión .php
# ============================================================

Options -MultiViews
DirectoryIndex index.php index.html
RewriteEngine On

# 0. Forzar HTTPS (301 permanente)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 1. Redirigir /pagina.php → /pagina (301 para SEO)
#    Captura cualquier petición que el navegador haga con .php en la URL
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. Reescritura interna: /pagina → /pagina.php
#    Solo si no es un directorio ni un fichero real ya existente
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# ============================================================
# Seguridad básica
# ============================================================

# Ocultar cabecera X-Powered-By
<IfModule mod_headers.c>
  Header unset X-Powered-By
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Desactivar directory listing
Options -Indexes

# Proteger includes
<FilesMatch "^(header|footer)\.php$">
  <IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/includes/
    RewriteRule .* - [F,L]
  </IfModule>
</FilesMatch>

# ============================================================
# Caché y rendimiento
# ============================================================

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css             "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml        "access plus 1 month"
  ExpiresByType image/jpeg           "access plus 1 month"
  ExpiresByType image/png            "access plus 1 month"
  ExpiresByType image/webp           "access plus 1 month"
  ExpiresByType font/woff2           "access plus 1 year"
</IfModule>

# Comprimir respuestas
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml
</IfModule>
